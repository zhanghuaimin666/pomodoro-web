# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=pomodoro
POSTGRES_PASSWORD=请替换为安全的密码
POSTGRES_DB=pomodoro

# ── Backend CORS ────────────────────────────────────────────
# 允许跨域请求的来源（JSON 数组格式）
BACKEND_CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]

# ── 仅本地开发用 ─────────────────────────────────────────────
# Docker Compose 运行时会自动使用 .env 中的 DATABASE_URL
# 本地直接启动后端时可以用这个连接本地数据库
DATABASE_URL=postgresql://pomodoro:请替换为安全的密码@localhost:5432/pomodoro
